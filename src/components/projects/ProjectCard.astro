---
import type { CollectionEntry } from 'astro:content';
import TagList from '../ui/TagList.astro';

type Project = CollectionEntry<'projects'>;

interface Props {
  project: Project;
  class?: string;
}

const { project, class: className } = Astro.props;
const { title, slug, summary, stack, cardVariant } = project.data;

const caseStudyHref = `/projects/${slug}`;

const thumbnailPatterns: Record<typeof cardVariant, string> = {
  'dark-globe': 'project-thumb-dark',
  'blue-cube': 'project-thumb-blue',
  'light-browser': 'project-thumb-browser',
  'light-wave': 'project-thumb-wave',
};
---

<a
  href={caseStudyHref}
  class:list={[
    'project-card group flex h-full min-w-0 flex-col overflow-hidden border border-border-ink bg-surface',
    className,
  ]}
>
  <div
    class:list={[
      'project-card__thumb relative h-[180px] w-full shrink-0 border-b border-border-ink',
      thumbnailPatterns[cardVariant],
    ]}
    aria-hidden="true"
  >
    <!-- TODO: replace with real SVG asset -->
    {
      cardVariant === 'dark-globe' && (
        <svg
          class="absolute inset-0 size-full text-accent/30"
          viewBox="0 0 160 100"
          preserveAspectRatio="xMidYMid slice"
          aria-hidden="true"
        >
          <circle cx="80" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="1" />
          <ellipse
            cx="80"
            cy="50"
            rx="28"
            ry="10"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          />
          <path d="M52 50h56M80 22v56" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
        </svg>
      )
    }
  </div>

  <div class="project-card__body flex flex-1 flex-col gap-2 p-4">
    <h3 class="project-card__title text-h3 font-bold text-ink group-hover:text-accent-deep">
      {title}
    </h3>
    <p class="project-card__summary text-small text-ink-muted">{summary}</p>
    <div class="project-card__tags mt-auto pt-1">
      <TagList tags={stack} />
    </div>
  </div>
</a>

<style>
  .project-card {
    border-radius: 12px;
    transition: all 200ms ease;
  }

  .project-card__thumb {
    border-radius: 12px 12px 0 0;
  }

  .project-card__title {
    line-height: 1.3;
  }

  .project-card__summary {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    overflow-wrap: break-word;
    word-break: normal;
  }

  .project-card__tags {
    font-size: 0.625rem;
    line-height: 1.3;
  }

  .project-card__tags :global(span) {
    font-size: inherit;
    line-height: inherit;
    padding-block: 0.125rem;
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 8px 24px rgba(90, 107, 181, 0.12),
      0 2px 8px rgba(10, 10, 10, 0.06);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card {
      transition: none;
    }

    .project-card:hover {
      transform: none;
    }
  }

  .project-thumb-dark {
    background-color: var(--color-surface-dark);
    background-image:
      linear-gradient(var(--color-accent-deep) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-accent-deep) 1px, transparent 1px);
    background-size: 12px 12px;
    background-position: center;
  }

  .project-thumb-blue {
    background-color: var(--color-accent-wash);
    background-image:
      linear-gradient(
        135deg,
        transparent 48%,
        var(--color-accent) 48%,
        var(--color-accent) 52%,
        transparent 52%
      ),
      linear-gradient(
        45deg,
        transparent 48%,
        var(--color-accent-deep) 48%,
        var(--color-accent-deep) 52%,
        transparent 52%
      );
    background-size: 16px 16px;
  }

  .project-thumb-browser {
    background-color: var(--color-surface);
    background-image:
      linear-gradient(var(--color-border-muted) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border-muted) 1px, transparent 1px);
    background-size: 8px 8px;
  }

  .project-thumb-wave {
    background-color: var(--color-canvas);
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-accent-glow),
      var(--color-accent-glow) 2px,
      transparent 2px,
      transparent 8px
    );
  }
</style>
