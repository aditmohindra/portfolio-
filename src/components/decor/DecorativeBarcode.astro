---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;

const width = Math.round(size * 0.35);
const height = size;
const barCount = 7;
const gap = width / (barCount * 2);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={width}
  height={height}
  viewBox={`0 0 ${width} ${height}`}
  fill="currentColor"
  class:list={['text-ink', className]}
  aria-hidden="true"
>
  {
    Array.from({ length: barCount }, (_, i) => {
      const x = i * (gap * 2) + gap * 0.5;
      const barHeight = height * (0.35 + (i % 3) * 0.2);
      const y = height - barHeight;
      return <rect x={x} y={y} width={gap} height={barHeight} />;
    })
  }
</svg>
