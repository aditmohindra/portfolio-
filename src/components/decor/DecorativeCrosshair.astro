---
interface Props {
  size?: number;
  class?: string;
}

const { size = 20, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 20 20"
  fill="none"
  stroke="currentColor"
  stroke-width="1"
  class:list={['text-ink-muted', className]}
  aria-hidden="true"
>
  <circle cx="10" cy="10" r="1.5" fill="currentColor" stroke="none"></circle>
  <path d="M10 2v16M2 10h16"></path>
  <path d="M4.5 4.5l11 11M15.5 4.5l-11 11" stroke-opacity="0.35"></path>
</svg>
