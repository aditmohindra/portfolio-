---
interface Props {
  size?: number;
  class?: string;
}

const { size = 16, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 16 16"
  fill="currentColor"
  class:list={['text-accent', className]}
  aria-hidden="true"
>
  <path d="M8 0L9.5 6.5L16 8L9.5 9.5L8 16L6.5 9.5L0 8L6.5 6.5L8 0Z"></path>
</svg>
