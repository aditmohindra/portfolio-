---
import Button from '../ui/Button.astro';
import { connectLinks } from '../../data/experience-hub';
import { siteConfig } from '../../data/site';
---

<section class="hub-card experience-connect" aria-labelledby="experience-connect-heading">
  <header class="hub-card__header">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 16 16"
      fill="currentColor"
      aria-hidden="true"
      class="hub-card__icon text-accent"
    >
      <path d="M8 0L9.5 6.5L16 8L9.5 9.5L8 16L6.5 9.5L0 8L6.5 6.5L8 0Z"></path>
    </svg>
    <h2 id="experience-connect-heading" class="hub-card__title">LET'S CONNECT</h2>
  </header>

  <p class="experience-connect__body">
    I'm always open to discussing new projects, collaborations, or just talking data + music.
  </p>

  <div class="experience-connect__actions">
    <Button variant="primary" href="/contact" class="experience-connect__btn">
      GET IN TOUCH →
    </Button>
    <Button variant="secondary" href={siteConfig.resumeHref} class="experience-connect__btn">
      VIEW RESUME ↓
    </Button>
  </div>

  <ul class="experience-connect__links">
    <li>
      <a
        href={`mailto:${connectLinks.email}`}
        class="experience-connect__row interactive-surface hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"
          aria-hidden="true"
          class="experience-connect__icon"
        >
          <rect x="3" y="5" width="18" height="14" rx="1"></rect>
          <path d="M3 7l9 7 9-7"></path>
        </svg>
        <span>{connectLinks.email}</span>
      </a>
    </li>
    <li>
      <a
        href={connectLinks.linkedin}
        class="experience-connect__row interactive-surface hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"
          aria-hidden="true"
          class="experience-connect__icon"
        >
          <rect x="3" y="3" width="18" height="18" rx="1"></rect>
          <path d="M8 11v6M8 8v.01M12 17v-6c0-1.5.75-2.5 2.25-2.5S16.5 9.5 16.5 11v6"></path>
        </svg>
        <span>linkedin.com/in/adit-mohindra</span>
      </a>
    </li>
    <li>
      <a
        href={connectLinks.github}
        class="experience-connect__row interactive-surface hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"
          aria-hidden="true"
          class="experience-connect__icon"
        >
          <path
            d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.6-.3 5.3-1.3 5.3-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.7 2.7 5.7 5.3 6-.6.6-.6 1.2-.5 2V21"
          ></path>
        </svg>
        <span>github.com/aditmohindra</span>
      </a>
    </li>
    <li>
      <span class="experience-connect__row">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="square"
          aria-hidden="true"
          class="experience-connect__icon"
        >
          <path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z"></path>
          <circle cx="12" cy="10" r="2.5"></circle>
        </svg>
        <span>Bay Area, CA</span>
      </span>
    </li>
  </ul>
</section>
