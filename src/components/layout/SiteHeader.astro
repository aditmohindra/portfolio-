---
import DecorativeStar from '../decor/DecorativeStar.astro';
import DecorativeBarcode from '../decor/DecorativeBarcode.astro';
import Container from './Container.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: NavItem[];
  isActive: (href: string) => boolean;
}

const { navItems, isActive } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border-ink bg-canvas">
  <Container>
    <div class="flex items-stretch gap-4 py-3">
      <div class="flex items-center gap-3">
        <a
          href="/"
          class="interactive-surface flex min-h-11 min-w-11 items-center justify-center focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
          aria-label="Adit Mohindra home"
        >
          <DecorativeStar size={14} />
        </a>
      </div>

      <nav aria-label="Primary" class="flex flex-1 items-center justify-center">
        <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 sm:gap-x-8">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'interactive-surface relative inline-flex min-h-11 items-center text-label text-ink-muted hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring',
                    isActive(item.href) &&
                      'text-ink after:absolute after:-bottom-3 after:left-1/2 after:size-1.5 after:-translate-x-1/2 after:rounded-full after:bg-accent-deep',
                  ]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="hidden items-center sm:flex" aria-hidden="true">
        <DecorativeBarcode size={28} />
      </div>
    </div>
  </Container>
</header>
