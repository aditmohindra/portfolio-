---
import Container from './Container.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  navItems: NavItem[];
  isActive: (href: string) => boolean;
}

const { navItems, isActive } = Astro.props;
---

<header class="border-b border-border-ink bg-canvas">
  <Container>
    <div class="flex flex-col gap-4 py-4 sm:flex-row sm:items-center sm:justify-between">
      <a href="/" class="font-mono text-sm uppercase tracking-widest text-ink"> Adit Mohindra </a>
      <nav aria-label="Primary">
        <ul class="flex flex-wrap gap-x-4 gap-y-2">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'font-mono text-xs uppercase tracking-widest text-ink-muted hover:text-ink',
                    isActive(item.href) && 'text-ink underline underline-offset-4',
                  ]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </Container>
</header>
