---
import ExternalLink from '../ui/ExternalLink.astro';
import { Image } from 'astro:assets';
import portrait from '../../assets/images/portrait.png';
import { siteConfig } from '../../data/site';

const quickFacts = [
  {
    key: 'based-in',
    label: 'Based in',
    value: siteConfig.location,
    icon: 'location',
  },
  {
    key: 'focus',
    label: 'Focus',
    value: siteConfig.focus,
    icon: 'focus',
  },
  {
    key: 'education',
    label: 'Education',
    value: siteConfig.education,
    icon: 'education',
  },
  {
    key: 'currently',
    label: 'Currently',
    value: siteConfig.currentBuild,
    icon: 'currently',
  },
  {
    key: 'availability',
    label: 'Availability',
    value: siteConfig.availability,
    icon: 'availability',
  },
] as const;

const contactLinks = [
  {
    key: 'email',
    href: `mailto:${siteConfig.social.email}`,
    label: 'Email',
    icon: 'email',
    external: false,
  },
  {
    key: 'linkedin',
    href: siteConfig.social.linkedin,
    label: 'LinkedIn',
    icon: 'linkedin',
    external: true,
  },
  {
    key: 'github',
    href: siteConfig.social.github,
    label: 'GitHub',
    icon: 'github',
    external: true,
  },
  {
    key: 'resume',
    href: siteConfig.resumeHref,
    label: 'Resume',
    icon: 'resume',
    external: false,
  },
] as const;

/** Decorative stat rows — static placeholders, not live telemetry */
const systemStats = [
  { label: 'Uptime', value: '99.97%' },
  { label: 'Response', value: '12ms' },
  { label: 'Last Login', value: '2026-06-18' },
  { label: 'System Time', value: '14:32:07 UTC' },
] as const;

const iconPaths = {
  location: 'M12 21s7-4.5 7-11a7 7 0 1 0-14 0c0 6.5 7 11 7 11zm0-9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z',
  focus:
    'M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83',
  education: 'M4 8l8-4 8 4-8 4-8-4zm0 0v8l8 4 8-4V8',
  currently:
    'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  availability: 'M20 6L9 17l-5-5',
  email: 'M4 6h16v12H4V6zm0 0l8 6 8-6',
  linkedin:
    'M6 9h3v12H6V9zm1.5-6A1.5 1.5 0 1 1 6 4.5 1.5 1.5 0 0 1 7.5 3zM11 9h3v1.7h.1c.4-.8 1.5-1.7 3.1-1.7 3.3 0 3.9 2.2 3.9 5v6.3h-3v-5.6c0-1.3 0-3-1.8-3s-2.1 1.4-2.1 2.9V21h-3V9z',
  github:
    'M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.69c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.56 9.56 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .26.18.58.69.48A10 10 0 0 0 12 2z',
  resume: 'M8 3h8l4 4v14H8V3zm2 2v16h8V7h-4V5H10zm2 8h4v2h-4v-2zm0 4h4v2h-4v-2z',
} as const;
---

<aside
  class="w-full shrink-0 self-stretch border border-border-ink bg-surface lg:w-72"
  aria-label="Profile sidebar"
>
  <!-- Identity -->
  <section
    class="border-b border-border-muted px-block py-block"
    aria-labelledby="sidebar-identity"
  >
    <p id="sidebar-identity" class="text-micro text-ink-muted">SYS/USER</p>
    <div class="mt-2 flex flex-col leading-none">
      <span class="text-label font-semibold text-ink">ADIT</span>
      <span class="text-label font-semibold text-ink">MOHINDRA</span>
    </div>
    <div class="mt-2 flex items-center gap-2">
      <p class="text-micro uppercase tracking-wide text-ink-muted">{siteConfig.sidebarTagline}</p>
      <span class="size-2 shrink-0 rounded-full bg-status-active" role="img" aria-label="Active"
      ></span>
    </div>
  </section>

  <!-- Portrait (frame labels are baked into the image asset) -->
  <section class="border-b border-border-muted px-block py-block" aria-label="User portrait">
    <Image
      src={portrait}
      alt="Pixel art portrait of Adit Mohindra in a system-style frame"
      width={576}
      height={576}
      widths={[288, 576]}
      quality={100}
      format="png"
      class="aspect-square w-full [image-rendering:pixelated]"
      loading="eager"
    />
  </section>

  <!-- Quick facts -->
  <section class="border-b border-border-muted px-block py-block" aria-labelledby="sidebar-facts">
    <p id="sidebar-facts" class="text-micro text-ink-muted">QUICK.FACTS</p>
    <dl class="mt-3 flex flex-col gap-2.5">
      {
        quickFacts.map((fact) => (
          <div class="flex gap-2.5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="square"
              class="mt-0.5 shrink-0 text-accent-deep"
              aria-hidden="true"
            >
              <path d={iconPaths[fact.icon]} />
            </svg>
            <div class="min-w-0">
              <dt class="text-micro text-ink-muted">{fact.label}</dt>
              <dd class="text-small text-ink">{fact.value}</dd>
            </div>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Contact -->
  <section class="border-b border-border-muted px-block py-block" aria-labelledby="sidebar-contact">
    <p id="sidebar-contact" class="text-micro text-ink-muted">CONTACT</p>
    <nav class="mt-3" aria-label="Contact links">
      <ul class="flex flex-col gap-1">
        {
          contactLinks.map((link) => (
            <li>
              <ExternalLink
                href={link.href}
                showIcon={false}
                newTab={link.external}
                class="block min-h-11 w-full text-small no-underline hover:no-underline"
              >
                <span class="flex w-full items-center gap-2.5">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="square"
                    class="shrink-0 text-accent-deep"
                    aria-hidden="true"
                  >
                    <path d={iconPaths[link.icon]} />
                  </svg>
                  <span class="min-w-0 flex-1">{link.label}</span>
                  <span class="text-label text-accent-deep" aria-hidden="true">
                    →
                  </span>
                </span>
              </ExternalLink>
            </li>
          ))
        }
      </ul>
    </nav>
  </section>

  <!-- Status (decorative) -->
  <section class="px-block py-block" aria-labelledby="sidebar-status">
    <div class="flex items-center gap-2">
      <p id="sidebar-status" class="text-micro text-ink-muted">SYSTEM OPERATIONAL</p>
      <span
        class="size-2 shrink-0 rounded-full bg-status-active"
        role="img"
        aria-label="Operational"></span>
    </div>
    <dl class="mt-3 flex flex-col gap-1.5">
      {
        systemStats.map((stat) => (
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-micro text-ink-muted">{stat.label}</dt>
            <dd class="text-micro tabular-nums text-ink">{stat.value}</dd>
          </div>
        ))
      }
    </dl>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 80 24"
      width="80"
      height="24"
      class="mt-3 w-full max-w-[10rem] text-accent-deep"
      aria-hidden="true"
    >
      <path
        d="M0 18 L8 14 L16 16 L24 10 L32 12 L40 6 L48 8 L56 4 L64 7 L72 2 L80 5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="square"
        stroke-linejoin="miter"></path>
    </svg>
  </section>
</aside>
