---
interface Props {
  class?: string;
  /** Wider max-width for editorial pages (e.g. projects index). */
  wide?: boolean;
}

const { class: className, wide = false } = Astro.props;

const widthClass = wide ? 'max-w-[min(95vw,106.25rem)]' : 'max-w-7xl';
---

<div class:list={['mx-auto w-full px-4 sm:px-6 lg:px-8', widthClass, className]}>
  <slot />
</div>
