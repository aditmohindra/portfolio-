---
import Container from './Container.astro';
import ExternalLink from '../ui/ExternalLink.astro';
import DecorativeGlobe from '../decor/DecorativeGlobe.astro';
import Divider from '../ui/Divider.astro';
import { siteConfig } from '../../data/site';

const socialLinks = [
  { href: siteConfig.social.github, label: 'GitHub' },
  { href: siteConfig.social.linkedin, label: 'LinkedIn' },
  { href: `mailto:${siteConfig.social.email}`, label: 'Email' },
];
---

<footer class="border-t border-border-muted bg-canvas">
  <Container>
    <div class="flex flex-col gap-4 py-block">
      <Divider />
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-small text-ink">Let's build something meaningful.</p>
        <nav aria-label="Social links">
          <ul class="flex flex-wrap items-center gap-x-4 gap-y-2">
            {
              socialLinks.map((link) => (
                <li>
                  <ExternalLink
                    href={link.href}
                    label={link.label}
                    class="text-label"
                    newTab={!link.href.startsWith('mailto:')}
                  />
                </li>
              ))
            }
          </ul>
        </nav>
        <div class="flex items-center gap-2 text-small text-ink-muted">
          <DecorativeGlobe size={20} />
          <span>&copy; {new Date().getFullYear()} Adit Mohindra</span>
        </div>
      </div>
    </div>
  </Container>
</footer>
