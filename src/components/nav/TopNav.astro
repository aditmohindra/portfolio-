---
import { siteConfig } from '../../data/site';

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(`${href}/`);
}

interface NavItem {
  label: string;
  href: string;
  /** Direct file download instead of a page navigation. */
  download?: boolean;
}

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'Experience', href: '/experience' },
  { label: 'Contact', href: '/contact' },
  { label: 'Resume', href: siteConfig.resumeHref, download: true },
  { label: 'Creative', href: '/creative' },
];
---

<nav
  aria-label="Main navigation"
  class="top-nav sticky top-0 z-50 w-full border-b border-border-ink bg-[rgba(255,255,255,0.85)] backdrop-blur-[8px]"
>
  <div
    class="mx-auto flex w-full max-w-[min(95vw,100rem)] items-center justify-between gap-4 px-4 py-2.5 sm:px-6"
  >
    <a
      href="/"
      class="font-nav text-label font-normal uppercase text-ink interactive-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
    >
      ADIT MOHINDRA
    </a>

    <div
      class="top-nav__links font-nav flex flex-wrap items-center justify-end gap-x-8 text-label font-normal uppercase"
    >
      {
        navItems.map((item) => {
          const active = !item.download && isActive(item.href);
          return (
            <a
              href={item.href}
              download={item.download ? '' : undefined}
              class:list={[
                'interactive-surface relative inline-flex items-center pb-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring',
                active ? 'text-accent' : 'text-ink-muted hover:text-ink',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {item.label}
              {active ? (
                <span
                  class="absolute bottom-0 left-1/2 size-1.5 -translate-x-1/2 rounded-full bg-accent"
                  aria-hidden="true"
                />
              ) : null}
            </a>
          );
        })
      }
    </div>
  </div>
</nav>
