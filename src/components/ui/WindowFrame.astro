---
interface Props {
  title: string;
  class?: string;
  compact?: boolean;
}

const { title, class: className, compact = false } = Astro.props;
---

<div
  class:list={['border border-border-ink bg-surface', className]}
  role="group"
  aria-label={title}
>
  <div
    class:list={[
      'flex items-center gap-2 border-b border-border-ink',
      compact ? 'px-2.5 py-1.5' : 'px-3 py-2',
    ]}
  >
    <div class="flex items-center gap-1.5" aria-hidden="true">
      <span class="size-2.5 border border-border-ink bg-surface"></span>
      <span class="size-2.5 border border-border-ink bg-surface"></span>
      <span class="size-2.5 border border-border-ink bg-surface"></span>
    </div>
    <p class="min-w-0 flex-1 truncate text-micro uppercase tracking-widest text-ink-muted">
      {title}
    </p>
    <div class="shrink-0">
      <slot name="chrome" />
    </div>
  </div>
  <div class:list={[compact ? 'p-3' : 'p-block']}>
    <slot />
  </div>
</div>
