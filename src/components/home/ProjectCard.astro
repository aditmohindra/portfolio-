---
import type { CollectionEntry } from 'astro:content';
import Card from '../ui/Card.astro';
import TagList from '../ui/TagList.astro';
import ExternalLink from '../ui/ExternalLink.astro';

type Project = CollectionEntry<'projects'>;

interface Props {
  project: Project;
  class?: string;
}

const { project, class: className } = Astro.props;
const { title, slug, summary, stack, cardVariant, links } = project.data;

const cardVariantMap = {
  'dark-globe': 'dark',
  'blue-cube': 'accent',
  'light-browser': 'default',
  'light-wave': 'default',
} as const;

const cardTone = cardVariantMap[cardVariant];
const externalHref = links.demo || links.github || links.writeup || '';
const caseStudyHref = `/projects/${slug}`;

const thumbnailPatterns: Record<typeof cardVariant, string> = {
  'dark-globe': 'project-thumb-dark',
  'blue-cube': 'project-thumb-blue',
  'light-browser': 'project-thumb-browser',
  'light-wave': 'project-thumb-wave',
};
---

<Card variant={cardTone} as="article" class:list={['flex h-full flex-col !p-0', className]}>
  <a
    href={caseStudyHref}
    class="interactive-surface block focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
  >
    <div
      class:list={[
        'relative aspect-[16/10] border-b border-border-ink',
        thumbnailPatterns[cardVariant],
      ]}
      aria-hidden="true"
    >
      {
        cardVariant === 'dark-globe' && (
          <svg
            class="absolute inset-0 size-full text-accent/30"
            viewBox="0 0 160 100"
            preserveAspectRatio="xMidYMid slice"
            aria-hidden="true"
          >
            <circle cx="80" cy="50" r="28" fill="none" stroke="currentColor" stroke-width="1" />
            <ellipse
              cx="80"
              cy="50"
              rx="28"
              ry="10"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
            />
            <path d="M52 50h56M80 22v56" stroke="currentColor" stroke-width="0.5" opacity="0.5" />
          </svg>
        )
      }
    </div>
  </a>

  <div class="flex flex-1 flex-col gap-3 p-block">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-h3 text-inherit">
        <a
          href={caseStudyHref}
          class="interactive-surface hover:text-accent-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
        >
          {title}
        </a>
      </h3>
      {
        externalHref && (
          <ExternalLink
            href={externalHref}
            label={`External link for ${title}`}
            class="shrink-0 text-inherit"
            iconOnly
          />
        )
      }
    </div>
    <p class="text-small text-inherit opacity-80">{summary}</p>
    <TagList tags={stack} class="mt-auto" />
  </div>
</Card>

<style>
  .project-thumb-dark {
    background-color: var(--color-surface-dark);
    background-image:
      linear-gradient(var(--color-accent-deep) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-accent-deep) 1px, transparent 1px);
    background-size: 12px 12px;
    background-position: center;
  }

  .project-thumb-blue {
    background-color: var(--color-accent-wash);
    background-image:
      linear-gradient(
        135deg,
        transparent 48%,
        var(--color-accent) 48%,
        var(--color-accent) 52%,
        transparent 52%
      ),
      linear-gradient(
        45deg,
        transparent 48%,
        var(--color-accent-deep) 48%,
        var(--color-accent-deep) 52%,
        transparent 52%
      );
    background-size: 16px 16px;
  }

  .project-thumb-browser {
    background-color: var(--color-surface);
    background-image:
      linear-gradient(var(--color-border-muted) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border-muted) 1px, transparent 1px);
    background-size: 8px 8px;
  }

  .project-thumb-wave {
    background-color: var(--color-canvas);
    background-image: repeating-linear-gradient(
      -45deg,
      var(--color-accent-glow),
      var(--color-accent-glow) 2px,
      transparent 2px,
      transparent 8px
    );
  }
</style>
