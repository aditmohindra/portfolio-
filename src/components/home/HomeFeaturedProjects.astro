---
import { getCollection } from 'astro:content';
import { featuredProjectSlugs } from '../../data/experience-hub';

const projects = await getCollection('projects');
const featured = featuredProjectSlugs
  .map((slug) => projects.find((project) => project.data.slug === slug))
  .filter((project): project is NonNullable<typeof project> => Boolean(project));

const thumbTone: Record<string, string> = {
  'dark-globe': 'home-featured__thumb--dark',
  'blue-cube': 'home-featured__thumb--lavender',
  'light-browser': 'home-featured__thumb--browser',
  'light-wave': 'home-featured__thumb--default',
};
---

<section class="home-featured" aria-labelledby="home-featured-heading">
  <header class="home-featured__header">
    <h2 id="home-featured-heading" class="home-featured__title">FEATURED PROJECTS</h2>
    <a href="/projects" class="home-featured__link interactive-surface">VIEW ALL PROJECTS →</a>
  </header>

  <ul class="home-featured__grid" role="list">
    {
      featured.map((project) => {
        const { title, slug, summary, stack, image, cardVariant } = project.data;
        const tags = stack.slice(0, 4);
        return (
          <li>
            <a href={`/projects/${slug}`} class="home-featured__card interactive-surface">
              <div class:list={['home-featured__thumb', thumbTone[cardVariant]]}>
                {image ? (
                  <img src={image} alt="" loading="lazy" decoding="async" />
                ) : (
                  <span class="home-featured__thumb-empty" aria-hidden="true" />
                )}
              </div>
              <div class="home-featured__body">
                <h3 class="home-featured__name">{title}</h3>
                <p class="home-featured__summary">{summary}</p>
                <ul class="home-featured__tags" aria-label="Tech stack">
                  {tags.map((tag) => (
                    <li class="home-featured__tag">{tag}</li>
                  ))}
                </ul>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</section>

<style>
  .home-featured {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .home-featured__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .home-featured__title {
    margin: 0;
    font-size: var(--text-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
  }

  .home-featured__link {
    font-size: var(--text-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-deep);
    text-decoration: none;
  }

  .home-featured__link:hover {
    color: var(--color-ink);
  }

  .home-featured__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--spacing-grid);
    margin: 0;
    padding: 0;
    list-style: none;
    min-width: 0;
  }

  .home-featured__grid > li {
    min-width: 0;
  }

  .home-featured__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--color-border-ink);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background-color 0.2s ease;
  }

  .home-featured__card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-deep);
    background: rgba(255, 255, 255, 0.95);
    box-shadow:
      0 8px 24px rgba(90, 107, 181, 0.12),
      0 2px 8px rgba(10, 10, 10, 0.06);
  }

  .home-featured__thumb {
    position: relative;
    width: 100%;
    height: clamp(95px, 12vh, 135px);
    overflow: hidden;
    border-bottom: 1px solid var(--color-border-ink);
    background: var(--color-canvas);
  }

  .home-featured__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Spotify Atlas source art has its wordmark/globe anchored toward the top —
     align top so the logo isn't cropped by the wider thumbnail aspect ratio. */
  .home-featured__thumb--dark img {
    object-position: center top;
  }

  .home-featured__thumb-empty {
    display: block;
    width: 100%;
    height: 100%;
  }

  .home-featured__thumb--dark {
    background-color: var(--color-surface-dark);
  }

  .home-featured__thumb--lavender {
    background-color: var(--color-accent-wash);
  }

  .home-featured__thumb--browser,
  .home-featured__thumb--default {
    background-color: var(--color-canvas);
  }

  .home-featured__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.7rem 0.8rem 0.8rem;
  }

  .home-featured__name {
    margin: 0;
    font-size: var(--text-h3);
    font-weight: 700;
    line-height: 1.25;
    color: var(--color-ink);
  }

  .home-featured__card:hover .home-featured__name {
    color: var(--color-accent-deep);
  }

  .home-featured__summary {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: var(--text-small);
    line-height: 1.45;
    color: var(--color-ink-muted);
  }

  .home-featured__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: auto 0 0;
    padding: 0.3rem 0 0;
    list-style: none;
  }

  .home-featured__tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border-muted);
    background: var(--color-canvas);
    padding: 0.1rem 0.38rem;
    font-size: 0.625rem;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-featured__card {
      transition:
        border-color 0.2s ease,
        box-shadow 0.2s ease,
        background-color 0.2s ease;
    }

    .home-featured__card:hover {
      transform: none;
    }
  }
</style>
