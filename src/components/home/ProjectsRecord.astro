---
import RecordSection from '../ui/RecordSection.astro';
import ProjectCard from '../projects/ProjectCard.astro';
import { getCollection } from 'astro:content';

const homepageProjects = (await getCollection('projects'))
  .filter((project) => project.data.homepage)
  .sort((a, b) => a.data.order - b.data.order);
---

<RecordSection number="02" label="PROJECTS" href="/projects" linkLabel="View all projects">
  <div class="projects-card-grid">
    {homepageProjects.map((project) => <ProjectCard project={project} />)}
  </div>
</RecordSection>

<style>
  .projects-card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    align-items: stretch;
    gap: var(--spacing-grid);
  }
</style>
