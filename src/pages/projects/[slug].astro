---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} · Adit Mohindra`} description={project.data.summary}>
  <Container>
    <article class="py-12">
      <header class="mb-8 border-b border-border-muted pb-6">
        <h1 class="text-2xl font-semibold text-ink">{project.data.title}</h1>
        <p class="mt-2 text-sm text-ink-muted">
          {project.data.role} · {project.data.timeline} · {project.data.status}
        </p>
        <p class="mt-4 max-w-prose text-ink-muted">{project.data.summary}</p>
        <p class="mt-2 font-mono text-xs text-ink-muted">
          {project.data.stack.join(' · ')}
        </p>
      </header>
      <div class="prose max-w-prose text-ink">
        <Content />
      </div>
    </article>
  </Container>
</BaseLayout>
