---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import AwardItem from '../components/home/AwardItem.astro';
import { getCollection } from 'astro:content';

const awards = (await getCollection('awards')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Awards · Adit Mohindra" description="Awards and recognition.">
  <Container>
    <section class="py-section">
      <SectionHeader title="Awards & Recognition" />
      <div class="mt-block flex flex-col gap-block">
        {
          awards.map((entry) => (
            <AwardItem
              title={entry.data.title}
              organization={entry.data.organization}
              date={entry.data.date}
              description={entry.data.description}
              icon={entry.data.icon}
              link={entry.data.link}
            />
          ))
        }
      </div>
    </section>
  </Container>
</BaseLayout>
