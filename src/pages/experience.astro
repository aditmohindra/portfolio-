---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import { getCollection } from 'astro:content';

function parseStartDate(value: string): number {
  const parsed = Date.parse(value);
  return Number.isNaN(parsed) ? 0 : parsed;
}

const experience = (await getCollection('experience')).sort(
  (a, b) => parseStartDate(b.data.start) - parseStartDate(a.data.start),
);
---

<BaseLayout title="Experience · Adit Mohindra" description="Professional experience.">
  <Container>
    <section class="py-12">
      <h1 class="text-2xl font-semibold text-ink">Experience</h1>
      <ul class="mt-6 space-y-6">
        {
          experience.map((entry) => (
            <li class="border border-border-muted bg-surface p-4">
              <h2 class="font-medium text-ink">{entry.data.role}</h2>
              <p class="text-sm text-ink-muted">
                {entry.data.company} · {entry.data.location}
              </p>
              <p class="font-mono text-xs text-ink-muted">
                {entry.data.start} – {entry.data.end}
              </p>
              {entry.data.bullets.length > 0 && (
                <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-ink-muted">
                  {entry.data.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </section>
  </Container>
</BaseLayout>
