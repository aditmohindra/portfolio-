---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import { getCollection } from 'astro:content';

const experience = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Experience · Adit Mohindra" description="Professional experience.">
  <Container>
    <section class="py-12">
      <h1 class="text-2xl font-semibold text-ink">Experience</h1>
      <ul class="mt-6 space-y-6">
        {
          experience.map((entry) => (
            <li class="border border-border-muted bg-surface p-4">
              <h2 class="font-medium text-ink">{entry.data.title}</h2>
              <p class="text-sm text-ink-muted">
                {entry.data.company} · {entry.data.location}
              </p>
              <p class="font-mono text-xs text-ink-muted">
                {entry.data.start} – {entry.data.end}
              </p>
              <p class="mt-2 text-sm text-ink-muted">{entry.data.description}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </Container>
</BaseLayout>
