---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import DecorativeStar from '../components/decor/DecorativeStar.astro';
import ProjectsHeroGraphic from '../components/projects/ProjectsHeroGraphic.astro';
import ProjectsFilter from '../components/islands/ProjectsFilter';
import { getCollection } from 'astro:content';
import type { ProjectCardData } from '../data/project-filters';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const projectCards: ProjectCardData[] = projects.map((project) => {
  const { title, slug, summary, categories, stack, status, cardVariant, image, links } =
    project.data;
  const externalHref = links.demo || links.github || links.writeup || '';
  const comingSoon = (status ?? '').toLowerCase().includes('coming soon');

  return {
    id: project.id,
    title,
    slug,
    summary,
    categories,
    stack,
    status,
    cardVariant,
    image,
    externalHref,
    comingSoon,
  };
});
---

<BaseLayout
  title="Projects · Adit Mohindra"
  description="A selection of applied machine learning projects, data products, and interactive systems."
>
  <Container wide>
    <section class="projects-page">
      <div class="projects-page__header">
        <div class="projects-page__intro">
          <p class="projects-page__record">
            <span class="projects-page__record-dot" aria-hidden="true"></span>
            <span>SYS.RECORD 02 / PROJECTS</span>
          </p>

          <h1 class="projects-page__title">
            <DecorativeStar size={22} class="projects-page__sparkle" />
            <span class="projects-page__title-word">
              <span class="projects-page__title-accent font-accent">P</span><span
                class="projects-page__title-display font-display">rojects</span
              >
            </span>
            <DecorativeStar size={22} class="projects-page__sparkle" />
          </h1>

          <p class="projects-page__description">
            A selection of applied machine learning projects, data products, and interactive
            systems. Built to solve real problems and communicate insights clearly.
          </p>
        </div>

        <div class="projects-page__graphic">
          <ProjectsHeroGraphic />
        </div>
      </div>

      <ProjectsFilter client:idle projects={projectCards} />
    </section>
  </Container>
</BaseLayout>

<style>
  .projects-page {
    padding-block: 1.5rem 2.5rem;
  }

  .projects-page__header {
    display: grid;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 1024px) {
    .projects-page__header {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 2rem;
    }
  }

  .projects-page__intro {
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .projects-page__intro {
      max-width: calc(100% - 22rem);
    }
  }

  .projects-page__record {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.5rem;
    font-size: var(--text-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent-deep);
  }

  .projects-page__record-dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 9999px;
    background: var(--color-accent-deep);
  }

  .projects-page__title {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 0 0 0.65rem;
    color: var(--color-ink);
  }

  .projects-page__title-word {
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
  }

  .projects-page__title-accent {
    font-size: clamp(3.75rem, 7.5vw, 5.75rem);
    line-height: 1;
    -webkit-font-smoothing: none;
    -moz-osx-font-smoothing: unset;
    text-rendering: optimizeSpeed;
  }

  .projects-page__title-display {
    font-size: clamp(3.75rem, 7.5vw, 5.75rem);
    line-height: 0.95;
    font-weight: var(--text-display--font-weight);
  }

  .projects-page__sparkle {
    flex-shrink: 0;
  }

  .projects-page__description {
    margin: 0;
    max-width: 36rem;
    font-size: var(--text-small);
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  .projects-page__graphic {
    display: flex;
    justify-content: center;
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .projects-page__graphic {
      justify-content: flex-end;
    }
  }

  /* Filter island + cards — scoped via :global for React island */
  :global(.projects-filter__pills) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0;
  }

  :global(.projects-filter__divider) {
    margin: 1.25rem 0 1.5rem;
    border: 0;
    border-top: 1px solid var(--color-border-muted);
  }

  :global(.projects-filter__pill) {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--color-border-ink);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.04em;
    cursor: pointer;
    transition:
      color 150ms ease,
      background-color 150ms ease;
  }

  :global(.projects-filter__pill:hover) {
    color: var(--color-accent-deep);
  }

  :global(.projects-filter__pill--active) {
    background: var(--color-ink);
    color: var(--color-ink-on-dark);
  }

  :global(.projects-filter__pill--active:hover) {
    color: var(--color-ink-on-dark);
  }

  :global(.projects-filter__pill-dot) {
    position: absolute;
    bottom: -0.45rem;
    left: 50%;
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 9999px;
    background: var(--color-accent);
    transform: translateX(-50%);
  }

  :global(.projects-filter__grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-grid);
  }

  :global(.projects-filter__grid > div) {
    min-width: 0;
  }

  @media (min-width: 768px) {
    :global(.projects-filter__grid) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    :global(.projects-filter__grid) {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  :global(.projects-filter__empty) {
    margin-top: 1rem;
  }

  :global(.projects-card) {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.82);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  :global(.projects-card:hover) {
    transform: scale(1.02);
    border-color: var(--color-accent-deep);
    background: rgba(255, 255, 255, 0.95);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.projects-card) {
      transition:
        border-color 0.2s ease,
        background-color 0.2s ease;
    }

    :global(.projects-card:hover) {
      transform: none;
    }
  }

  :global(.projects-filter__grid > div:hover) {
    position: relative;
    z-index: 1;
  }

  :global(.projects-card__thumb) {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    border-bottom: 1px solid var(--color-border-ink);
    border-radius: 12px 12px 0 0;
    overflow: hidden;
  }

  :global(.projects-card__thumb-img) {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  :global(.projects-thumb--dark) {
    background-color: var(--color-surface-dark);
  }

  :global(.projects-thumb--lavender) {
    background-color: var(--color-accent-wash);
  }

  :global(.projects-thumb--browser),
  :global(.projects-thumb--default) {
    background-color: var(--color-canvas);
  }

  :global(.projects-thumb__window) {
    position: absolute;
    inset: 18% 22%;
    border: 1px solid var(--color-border-ink);
    background: var(--color-surface);
  }

  :global(.projects-thumb__window-bar) {
    display: flex;
    gap: 0.2rem;
    padding: 0.3rem 0.4rem;
    border-bottom: 1px solid var(--color-border-ink);
  }

  :global(.projects-thumb__window-bar span) {
    width: 0.35rem;
    height: 0.35rem;
    border: 1px solid var(--color-border-ink);
  }

  :global(.projects-thumb__window-body) {
    height: calc(100% - 1rem);
    background:
      linear-gradient(var(--color-border-muted) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border-muted) 1px, transparent 1px);
    background-size: 8px 8px;
  }

  :global(.projects-card__body) {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem;
  }

  :global(.projects-card__title-row) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  :global(.projects-card__title) {
    margin: 0;
    font-size: var(--text-h3);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-ink);
  }

  :global(.projects-card__external) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    min-height: 1.75rem;
    flex-shrink: 0;
  }

  :global(.projects-card__external--muted) {
    color: var(--color-border-muted);
  }

  :global(.projects-card__summary) {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-size: var(--text-small);
    line-height: 1.5;
    color: var(--color-ink-muted);
  }

  :global(.projects-card__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.projects-card__tag) {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border-muted);
    background: var(--color-canvas);
    padding: 0.125rem 0.4rem;
    font-size: 0.625rem;
    line-height: 1.3;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }

  :global(.projects-card__category) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: auto 0 0;
    padding-top: 0.35rem;
    font-size: var(--text-micro);
    letter-spacing: 0.04em;
    color: var(--color-ink-muted);
  }

  :global(.projects-card__category-dot) {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 9999px;
    background: var(--color-accent-deep);
  }

  :global(.projects-card__status) {
    color: var(--color-ink-muted);
  }
</style>
