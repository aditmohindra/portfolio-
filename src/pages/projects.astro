---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/layout/Container.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects · Adit Mohindra" description="Selected ML and data science projects.">
  <Container>
    <section class="py-12">
      <h1 class="text-2xl font-semibold text-ink">Projects</h1>
      <ul class="mt-6 space-y-4">
        {
          projects.map((project) => (
            <li class="border border-border-muted bg-surface p-4">
              <a
                href={`/projects/${project.data.slug}`}
                class="font-medium text-ink hover:underline"
              >
                {project.data.title}
              </a>
              <p class="mt-1 text-sm text-ink-muted">{project.data.summary}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </Container>
</BaseLayout>
